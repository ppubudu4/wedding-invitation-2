# Supabase — copy this file to .env.local and fill in from your Supabase project
# (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Your deployed site's public URL (no trailing slash). Required for correct
# WhatsApp / social link previews (Open Graph image + absolute URLs).
# Locally you can leave this as http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://your-wedding-site.com
